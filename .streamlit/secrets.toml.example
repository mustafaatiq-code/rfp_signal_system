# Streamlit secrets template — copy to .streamlit/secrets.toml for local use,
# or paste the values into the app's Secrets on Streamlit Community Cloud
# (Manage app → Settings → Secrets). The real secrets.toml is gitignored.

# Password required to open the dashboard. Leave unset/empty to disable the
# gate entirely (fine for local development).
dashboard_password = "change-me"

# Set to "true" on hosted read-only deployments (e.g. Streamlit Cloud). This
# hides the local-only "Refresh Data" button, which shells out to the live
# pipeline and cannot run on Cloud.
deployed = "false"
